{
	"compilerOptions": {
		"lib": ["ESNext"],
		"target": "ESNext",
		"module": "Preserve",
		"moduleResolution": "bundler",
		"paths": {
			"@/*": ["./packages/webui/src/*"],
			"@codeworksh/aikit": ["./packages/aikit/src/index"],
			"@codeworksh/aikit/codemode/drivers": ["./packages/aikit/src/agent/codemode/drivers/drivers"],
			"@codeworksh/bridge": ["./packages/bridge/src/index"],
			"@codeworksh/agent": ["./packages/agent/src/index"],
			"@codeworksh/sdk": ["./packages/sdk/src/index"],
			"@codeworksh/utils": ["./packages/utils/src/index"]
		},
		"types": ["node"],
		"verbatimModuleSyntax": true,
		"noEmit": true,
		"strict": true,
		"skipLibCheck": true,
		"noFallthroughCasesInSwitch": true,
		"noUncheckedIndexedAccess": true,
		"noImplicitOverride": true
	},
	"include": ["vite.config.ts"]
}

{
	"compilerOptions": {
		"lib": ["ESNext"],
		"target": "ESNext",
		"module": "Preserve",
		"moduleResolution": "bundler",
		"moduleDetection": "force",
		"resolveJsonModule": true,
		"isolatedModules": true,
		"esModuleInterop": true,
		"noUnusedLocals": true,
		"paths": {
			"@codeworksh/aikit": ["./packages/aikit/src/index"],
			"@codeworksh/harness/codemode/drivers": ["./packages/harness/src/harness/codemode/drivers/drivers"],
			"@codeworksh/harness": ["./packages/harness/src/index"],
			"@codeworksh/bridge": ["./packages/bridge/src/index"],
			"@codeworksh/agent": ["./packages/agent/src/index"],
			"@codeworksh/sdk": ["./packages/sdk/src/index"],
			"@codeworksh/utils": ["./packages/utils/src/index"]
		},
		"types": ["node"],
		"verbatimModuleSyntax": true,
		"noEmit": true,
		"strict": true,
		"skipLibCheck": true,
		"noFallthroughCasesInSwitch": true,
		"noUncheckedIndexedAccess": true,
		"noImplicitOverride": true
	},
	"include": ["vite.config.ts"]
}

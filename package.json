{
  "name": "codework",
  "version": "0.0.0",
  "private": true,
  "description": "AI toolkit and coding agents for building AI agents.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/codeworksh/codework.git"
  },
  "homepage": "https://github.com/codeworksh/codework",
  "bugs": {
    "url": "https://github.com/codeworksh/codework/issues"
  },
  "workspaces": [
    "packages/*"
  ],
  "catalog": {
    "@types/bun": "^1.3.9",
    "@sinclair/typebox": "^0.34.48",
    "typescript": "^5.8.3"
  },
  "scripts": {
    "lint": "biome lint packages/",
    "lint:fix": "biome lint --write packages/",
    "check": "biome check packages/",
    "check:fix": "biome check --write packages/",
    "publish:package": "bun run scripts/publish.ts",
    "publish:aikit": "bun run scripts/publish.ts aikit",
    "publish:aikit:dry": "bun run scripts/publish.ts aikit --dry-run",
    "publish:utils": "bun run scripts/publish.ts utils",
    "publish:utils:dry": "bun run scripts/publish.ts utils --dry-run"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.14",
    "@types/bun": "catalog:"
  }
}

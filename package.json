{
	"name": "codework",
	"version": "0.0.0",
	"private": true,
	"description": "AI toolkit and coding agents for building AI agents.",
	"homepage": "https://github.com/codeworksh/codework",
	"bugs": {
		"url": "https://github.com/codeworksh/codework/issues"
	},
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/codeworksh/codework.git"
	},
	"workspaces": [
		"packages/*"
	],
	"type": "module",
	"scripts": {
		"lint": "vp lint",
		"check": "vp check",
		"check:packages": "vp run -r check",
		"test": "vp test",
		"test:packages": "vp run -r test",
		"build": "vp run -r build",
		"build:packages": "vp run -r build",
		"server:start": "tsx --conditions=development packages/agent/src/index.ts serve",
		"server:dev": "node scripts/dev/server.mjs",
		"desktop:build": "pnpm --filter @codeworksh/desktop build",
		"desktop:start": "pnpm --filter @codeworksh/desktop start",
		"sdk:generate": "pnpm --filter @codeworksh/agent openapi && pnpm --filter @codeworksh/sdk generate && pnpm --filter @codeworksh/sdk build",
		"bump:aikit": "pnpm --filter @codeworksh/aikit run bump",
		"bump:sdk": "pnpm --filter @codeworksh/sdk run bump",
		"release:aikit": "pnpm --filter @codeworksh/aikit run release",
		"release:aikit:dev": "pnpm --filter @codeworksh/aikit run release:dev",
		"release:aikit:dry": "pnpm --filter @codeworksh/aikit run release:dry",
		"release:sdk": "pnpm --filter @codeworksh/sdk run release",
		"release:sdk:dev": "pnpm --filter @codeworksh/sdk run release:dev",
		"release:sdk:dry": "pnpm --filter @codeworksh/sdk run release:dry"
	},
	"devDependencies": {
		"@types/node": "^24.12.2",
		"@typescript/native-preview": "7.0.0-dev.20260328.1",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3",
		"vite-plus": "0.1.17"
	},
	"packageManager": "pnpm@10.25.0"
}

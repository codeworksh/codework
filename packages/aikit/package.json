{
	"name": "@codeworksh/aikit",
	"version": "0.3.1",
	"description": "Toolkit for building AI agents and agent harness.",
	"keywords": [
		"agent",
		"ai",
		"anthropic",
		"coding-agent",
		"nodejs",
		"streaming",
		"toolkit",
		"typescript"
	],
	"homepage": "https://github.com/codeworksh/codework/tree/main/packages/aikit",
	"bugs": {
		"url": "https://github.com/codeworksh/codework/issues"
	},
	"license": "MIT",
	"author": "Sanchit Kudari",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/codeworksh/codework.git",
		"directory": "packages/aikit"
	},
	"files": [
		"dist",
		"src",
		"README.md"
	],
	"type": "module",
	"types": "./dist/pack/index.d.mts",
	"exports": {
		".": {
			"types": "./dist/pack/index.d.mts",
			"import": "./dist/pack/index.mjs",
			"default": "./dist/pack/index.mjs"
		},
		"./agent/codemode/drivers/drivers": {
			"types": "./dist/pack/agent/codemode/drivers/drivers.d.mts",
			"import": "./dist/pack/agent/codemode/drivers/drivers.mjs",
			"default": "./dist/pack/agent/codemode/drivers/drivers.mjs"
		},
		"./package.json": "./package.json"
	},
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"build": "vp pack",
		"bump": "bumpp",
		"check": "vp check",
		"lint": "vp lint",
		"test": "vp test"
	},
	"dependencies": {
		"@anthropic-ai/sdk": "^0.80.0",
		"@sinclair/typebox": "^0.34.48",
		"ajv": "^8.18.0",
		"ajv-formats": "^3.0.1",
		"esbuild": "^0.27.3",
		"openai": "^6.34.0",
		"partial-json": "^0.1.7",
		"quickjs-wasi": "^2.2.0",
		"remeda": "^2.33.6",
		"uuidv7": "^1.2.1"
	},
	"devDependencies": {
		"@codeworksh/utils": "workspace:*",
		"bumpp": "^11.0.1"
	},
	"peerDependencies": {
		"typescript": "^5"
	},
	"engines": {
		"node": ">=24.14.1"
	}
}

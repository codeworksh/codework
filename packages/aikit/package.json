{
	"name": "@codeworksh/aikit",
	"version": "0.4.0",
	"description": "Toolkit for building AI agents and agent harness.",
	"keywords": [
		"agent",
		"ai",
		"anthropic",
		"coding-agent",
		"nodejs",
		"streaming",
		"toolkit",
		"typescript"
	],
	"homepage": "https://github.com/codeworksh/codework/tree/main/packages/aikit",
	"bugs": {
		"url": "https://github.com/codeworksh/codework/issues"
	},
	"license": "MIT",
	"author": "Sanchit Kudari",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/codeworksh/codework.git",
		"directory": "packages/aikit"
	},
	"bin": {
		"codework-aikit": "./dist/pack/cli.mjs"
	},
	"files": [
		"dist",
		"src",
		"README.md"
	],
	"type": "module",
	"types": "./dist/pack/index.d.mts",
	"exports": {
		".": {
			"types": "./dist/pack/index.d.mts",
			"import": "./dist/pack/index.mjs",
			"default": "./dist/pack/index.mjs"
		},
		"./oauth/openai-codex": {
			"types": "./dist/pack/oauth/openai/codex.d.mts",
			"import": "./dist/pack/oauth/openai/codex.mjs",
			"default": "./dist/pack/oauth/openai/codex.mjs"
		},
		"./package.json": "./package.json"
	},
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"build": "vp pack",
		"bump": "bumpp",
		"check": "vp check",
		"cli": "tsx --conditions=development src/cli.ts",
		"lint": "vp lint",
		"test": "vp test"
	},
	"dependencies": {
		"@ai-sdk/anthropic": "^3.0.79",
		"@ai-sdk/google": "^3.0.79",
		"@ai-sdk/google-vertex": "^4.0.137",
		"@ai-sdk/openai": "^3.0.65",
		"@ai-sdk/openai-compatible": "^2.0.48",
		"@ai-sdk/provider": "^3.0.10",
		"@ai-sdk/xai": "^3.0.92",
		"@openrouter/ai-sdk-provider": "^2.9.0",
		"ai": "^6.0.191",
		"dedent": "^1.7.2",
		"esbuild": "^0.27.3",
		"partial-json": "^0.1.7",
		"quickjs-wasi": "^2.2.0",
		"remeda": "^2.33.6",
		"typebox": "^1.1.37",
		"uuidv7": "^1.2.1",
		"yargs": "^18.0.0"
	},
	"devDependencies": {
		"@codeworksh/utils": "workspace:*",
		"@fontsource/iosevka": "^5.2.5",
		"@types/yargs": "^17.0.35",
		"bumpp": "^11.0.1"
	},
	"engines": {
		"node": ">=24.14.1"
	}
}

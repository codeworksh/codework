{
	"extends": "../../tsconfig.json",
	"compilerOptions": {
		"lib": ["ES2022", "DOM", "DOM.Iterable"],
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"resolveJsonModule": true,
		"jsx": "react-jsx",
		"paths": {
			"@/*": ["./src/*"],
			"@codeworksh/aikit": ["../aikit/src/index.ts"],
			"@codeworksh/aikit/codemode/drivers": ["../aikit/src/agent/codemode/drivers/drivers.ts"],
			"@codeworksh/bridge": ["../bridge/src/index.ts"],
			"@codeworksh/utils": ["../utils/src/index.ts"]
		},
		"types": ["vite/client"],
		"noEmit": true
	},
	"include": ["src", "vite.config.ts"]
}

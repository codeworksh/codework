{
	"name": "@codeworksh/desktop",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"main": "dist/electron/main.cjs",
	"scripts": {
		"dev": "node scripts/dev.mjs",
		"dev:bundle": "vp pack --watch",
		"dev:renderer": "vite --config vite.renderer.config.ts",
		"dev:electron": "node scripts/reload.mjs",
		"build": "vp pack && vite build --config vite.renderer.config.ts",
		"lint": "vp lint",
		"start": "node scripts/start.mjs",
		"check": "vp check",
		"smoke-test": "node scripts/smoke.mjs"
	},
	"dependencies": {
		"electron": "^40.6.0",
		"react": "^19.0.0",
		"react-dom": "^19.0.0"
	},
	"devDependencies": {
		"@types/node": "^24.6.1",
		"@types/react": "^19.0.0",
		"@types/react-dom": "^19.0.0",
		"@vitejs/plugin-react": "^6.0.0",
		"vite": "^8.0.0"
	},
	"engines": {
		"node": ">=24.14.1"
	},
	"productName": "Codework"
}
